# ==================================
# 🔐 환경변수 설정 가이드
# ==================================

# ----------------------------------
# 1. 데이터베이스 설정
# ----------------------------------
# 개발 환경: SQLite (로컬 파일 기반)
DATABASE_URL="file:./dev.db"

# 프로덕션 환경: PostgreSQL (Railway에서 자동 생성)
# Railway PostgreSQL 플러그인 추가 시 자동으로 생성됩니다
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# ----------------------------------
# 2. JWT 인증 시크릿 키 ⚠️ 필수
# ----------------------------------
# 강력한 랜덤 문자열 사용 (최소 32자 이상 권장)
# 생성 방법: openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# NextAuth Secret (JWT_SECRET과 동일하게 사용 가능)
NEXTAUTH_SECRET="your-super-secret-jwt-key-change-this-in-production"

# NextAuth URL (개발/프로덕션 URL)
NEXTAUTH_URL="https://qrlive.io"
# NEXTAUTH_URL="http://localhost:3000"  # 개발 환경

# ----------------------------------
# 3. 소셜 로그인 (OAuth) ⚠️ 필수
# ----------------------------------
# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Kakao OAuth (https://developers.kakao.com)
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# ----------------------------------
# 4. 이메일 알림 (SMTP) ⚠️ 필수
# ----------------------------------
# Gmail SMTP 설정 예시
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"
SMTP_FROM="Live Commerce <noreply@yourapp.com>"

# 또는 SendGrid
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_USER="apikey"
# SMTP_PASSWORD="your-sendgrid-api-key"

# ----------------------------------
# 5. KISPG (키스정보통신) 결제 API ⚠️ 필수
# ----------------------------------
# 개발: 테스트 환경 (testapi.kispg.co.kr)
KISPG_MODE="test"
KISPG_MID="kistest00m"
KISPG_MERCHANT_KEY="2d6ECGhR1pg/1QGE1lcRI4awsWEgshjEyI8UgYslLPJSuNeyPTkdrT8XWARezvDTUJClWQWhjxzBbu7AsuLZqg=="

# 프로덕션: 실제 가맹점 정보로 변경 필요 (api.kispg.co.kr)
# KISPG_MODE="production"
# KISPG_MID="실제_가맹점ID"
# KISPG_MERCHANT_KEY="실제_merchantKey"

# ----------------------------------
# 6. 서버 설정
# ----------------------------------
# 서버 포트 (Railway는 자동으로 PORT 환경변수 설정)
PORT=3000

# Node 환경
NODE_ENV="development"
# NODE_ENV="production"  # 프로덕션 배포 시

# ----------------------------------
# 7. 애플리케이션 URL
# ----------------------------------
# 개발: 로컬호스트
NEXT_PUBLIC_APP_URL="https://qrlive.io"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"  # 개발 환경

# 프로덕션: Railway 배포 URL 또는 커스텀 도메인
# NEXT_PUBLIC_APP_URL="https://your-app.railway.app"
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ----------------------------------
# 8. Socket.io 설정 (선택사항)
# ----------------------------------
# 개발 환경에서는 기본 포트 3015 사용
# 프로덕션에서는 동일 서버에서 실행 (포트 공유)

# ----------------------------------
# 📝 Railway 배포 시 설정할 환경변수
# ----------------------------------
# 1. DATABASE_URL: PostgreSQL 플러그인 추가 시 자동 생성
# 2. JWT_SECRET: openssl rand -hex 32 실행 결과 입력
# 3. NEXTAUTH_SECRET: JWT_SECRET과 동일 값 입력
# 4. NEXTAUTH_URL: https://your-app.railway.app
# 5. GOOGLE_CLIENT_ID: Google OAuth 클라이언트 ID
# 6. GOOGLE_CLIENT_SECRET: Google OAuth 시크릿
# 7. KAKAO_CLIENT_ID: Kakao REST API 키
# 8. KAKAO_CLIENT_SECRET: Kakao 클라이언트 시크릿
# 9. SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD, SMTP_FROM
# 10. KISPG_MODE: test 또는 production
# 11. KISPG_MID: KISPG 가맹점 ID
# 12. KISPG_MERCHANT_KEY: KISPG merchantKey (SHA-256 해시용)
# 12. NODE_ENV: production
# 13. NEXT_PUBLIC_APP_URL: https://your-app.railway.app
# 14. PORT: Railway가 자동 설정 (직접 설정 불필요)

# ----------------------------------
# 🔒 보안 주의사항
# ----------------------------------
# ⚠️ 절대 Git에 실제 키를 커밋하지 마세요!
# ⚠️ .env 파일은 .gitignore에 포함되어야 합니다
# ⚠️ 프로덕션 키는 반드시 별도로 관리하세요
# ⚠️ Gmail 사용 시 앱 비밀번호 발급 필요 (https://support.google.com/accounts/answer/185833)
